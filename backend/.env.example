PROXY_PORT=3000
ACTUAL_PROMETHEUS_URL=http://164.68.105.203:9090
NODE_ENV=production

# GitHub incidents integration
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_REPO_OWNER=your_github_username_or_org_name
GITHUB_REPO_NAME=your_repository_name_for_issues
GITHUB_INCIDENT_LABEL=incident

# Unified service config (replaces proxy-services-config.yaml for v2 API)
SERVICES_CONFIG_PATH=/usr/src/app/config/services.yaml

# v2 API (enabled by default)
API_V2_ENABLED=true

# Set to true once Prometheus recording rules are deployed
USE_RECORDING_RULES=false

# CORS origin for production
CORS_ORIGIN=https://status.stakecraft.com

# Public status page URL (used in RSS feed links)
STATUS_PAGE_URL=https://status.stakecraft.com