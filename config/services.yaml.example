# Stakecraft Status Page — Unified Service Configuration (v2)
#
# Single source of truth for:
#   - Public status page (via backend API)
#   - Grafana dashboard service list
#   - Prometheus recording rule generation
#
# Copy to services.yaml and customize prometheus_job values for your environment.
# DO NOT commit services.yaml if it contains environment-specific secrets.

version: 2

defaults:
  category: node
  network: mainnet
  public: true
  health:
    type: up

categories:
  website:
    label: Websites
    order: 1
  node:
    label: Nodes
    order: 2
  indexer:
    label: Indexers
    order: 3
  oracle:
    label: Oracles
    order: 4
  collator:
    label: Collators
    order: 5

services:
  - id: stakecraft-com
    name: Stakecraft.com
    category: website
    icon: https://stakecraft.com/assets/headerLogo-CfNQNJUs.svg
    health:
      type: threshold
      query: probe_success{job="blackbox-stakecraft-com"}
      condition: "== 1"

  - id: solana
    name: Solana Mainnet Node
    category: node
    icon: https://assets.coingecko.com/coins/images/4128/small/solana.png
    health:
      prometheus_job: solana-mainnet

  - id: walrus
    name: Walrus Mainnet Node
    category: node
    icon: https://assets.coingecko.com/coins/images/54914/standard/WAL_logo.png?1742494301
    health:
      prometheus_job: walrus-mainnet

  - id: kava
    name: Kava Mainnet Node
    category: node
    icon: https://assets.coingecko.com/coins/images/9761/standard/kava.png?1696509822
    health:
      prometheus_job: kava-mainnet

