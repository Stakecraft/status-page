# Copy to secret.env and apply with:
# kubectl create secret generic status-page-api-env --from-env-file=secret.env -n status-page

PROXY_PORT=3333
NODE_ENV=production
ACTUAL_PROMETHEUS_URL=http://your-prometheus-host:9090

GITHUB_TOKEN=
GITHUB_REPO_OWNER=Stakecraft
GITHUB_REPO_NAME=status-page
GITHUB_INCIDENT_LABEL=incident

API_V2_ENABLED=true
USE_RECORDING_RULES=false

CORS_ORIGIN=https://status.stakecraft.com
STATUS_PAGE_URL=https://status.stakecraft.com
